{
  "name": "tabnative",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "predev": "node scripts/prepare-assets.mjs",
    "dev": "vinext dev",
    "prebuild": "node scripts/prepare-assets.mjs",
    "build": "vinext build",
    "postbuild": "node scripts/finalize-worker-assets.mjs",
    "start": "vinext start",
    "test": "vitest run --config vitest.config.ts",
    "test:render": "npm run build && node --test tests/rendered-html.test.mjs tests/ai-directory-rendered.test.mjs tests/worker-assets.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern public/draco --ignore-pattern public/pdf.worker.min.mjs",
    "check": "tsc --noEmit && npm run lint && npm run test && npm run build && npm run test:render"
  },
  "dependencies": {
